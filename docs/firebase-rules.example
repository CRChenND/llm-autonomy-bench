rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Anonymous Firebase Auth counts as signed in. The app stores a
    // user-visible annotatorId separately so annotators can retrieve work
    // by the same ID across sessions/devices.
    function signedIn() {
      return request.auth != null;
    }

    match /annotationProjects/{projectId} {
      allow read: if signedIn();
      allow write: if false;

      match /cases/{caseId} {
        allow read: if signedIn();
        allow create, update: if signedIn();
        allow delete: if false;
      }

      match /annotations/{annotationId} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && request.resource.data.annotatorUid == request.auth.uid;
        allow delete: if signedIn()
          && resource.data.annotatorUid == request.auth.uid;
      }
    }
  }
}
