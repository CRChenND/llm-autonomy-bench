# Copy this file to .env and fill in local credentials.
# .env is ignored by git.

HF_TOKEN=

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter model ids look like: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, google/gemini-2.5-flash
LLM_MODEL=openai/gpt-4o-mini

# OpenAI direct alternative:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional knobs:
# LLM_MAX_TOKENS=5000
# LLM_RETRIES=4
# LLM_CONCURRENCY=4
# MIN_TOTAL_TURNS=7
# MIN_USER_TURNS=2
# MAX_RECORDS_PER_DATASET=5000
# OUTPUT_DIR=data/autonomy_seed_cases
